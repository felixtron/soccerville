generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  CAPTAIN
  STUDENT
}

enum TournamentStatus {
  OPEN
  FULL
  IN_PROGRESS
  FINISHED
}

enum TournamentSchedule {
  NOCTURNO
  VESPERTINO
  MATUTINO
  SABATINO
  DOMINICAL
}

enum TournamentCategory {
  VARONIL
  FEMENIL
  VETERANOS
  MIXTO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  INSCRIPTION
  REFEREE
  BOOKING
  FOODTRUCK
  ADVERTISING
  EVENT
  SCHOOL_FEE
}

enum SpaceType {
  FOODTRUCK
  ADVERTISING
  EVENT
}

enum SpaceStatus {
  AVAILABLE
  RENTED
}

enum NotificationAudience {
  ALL
  VENUE
  TOURNAMENT
  TEAM
  SCHOOL
}

enum ProgramType {
  SCHOOL
  FIXED_TEAM
}

enum MatchStatus {
  SCHEDULED
  PLAYED
  CANCELLED
  DEFAULTED
  ABANDONED
}

enum MatchEventType {
  GOAL
  OWN_GOAL
  YELLOW_CARD
  RED_CARD
  SANCTION
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  phone             String?
  password          String
  role              UserRole           @default(CAPTAIN)
  venueId           String?
  venue             Venue?             @relation(fields: [venueId], references: [id])
  team              Team?
  enrollments       SchoolEnrollment[]
  payments          Payment[]
  notifications     Notification[]
  notificationReads NotificationRead[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Venue {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  address          String
  phone            String
  whatsapp         String
  googleMapsUrl    String?
  fieldRentalPrice Int      @default(550)
  hasParking       Boolean  @default(true)
  hasBathrooms     Boolean  @default(true)
  hasLockers       Boolean  @default(true)
  hasLighting      Boolean  @default(true)
  operatingHours   String?
  imageUrl         String?
  stripeAccountId  String?
  stripeOnboarded  Boolean  @default(false)
  tournaments      Tournament[]
  bookings         Booking[]
  programs         Program[]
  spaces           CommercialSpace[]
  operators        User[]
  payments         Payment[]
  notifications    Notification[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Tournament {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  venueId         String
  venue           Venue              @relation(fields: [venueId], references: [id])
  category        TournamentCategory @default(VARONIL)
  schedule        TournamentSchedule
  maxTeams        Int
  inscriptionFee      Int
  refereeFee          Int
  refereeFeePerMatch  Boolean            @default(true)
  status              TournamentStatus   @default(OPEN)
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  teams           TournamentTeam[]
  matches         Match[]
  standings       Standing[]
  notifications   Notification[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([venueId])
}

model Team {
  id          String           @id @default(cuid())
  name        String
  captainId   String           @unique
  captain     User             @relation(fields: [captainId], references: [id])
  logoUrl     String?
  tournaments TournamentTeam[]
  homeMatches   Match[]          @relation("HomeTeam")
  awayMatches   Match[]          @relation("AwayTeam")
  standings     Standing[]
  players       Player[]
  notifications Notification[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Player {
  id       String       @id @default(cuid())
  name     String
  number   Int?
  position String?
  teamId   String
  team     Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  events   MatchEvent[]

  @@index([teamId])
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  groupName       String?
  inscriptionPaid Boolean    @default(false)
  enrolledAt      DateTime   @default(now())

  @@unique([tournamentId, teamId])
}

model Match {
  id           String       @id @default(cuid())
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchDay     Int
  homeTeamId   String
  homeTeam     Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String
  awayTeam     Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore    Int?
  awayScore    Int?
  date         DateTime?
  time         String?
  fieldNumber  Int?
  groupName    String?
  status       MatchStatus  @default(SCHEDULED)
  events       MatchEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tournamentId])
}

model MatchEvent {
  id        String         @id @default(cuid())
  matchId   String
  match     Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamId    String
  type      MatchEventType
  minute    Int?
  notes     String?
  createdAt DateTime       @default(now())

  @@index([matchId])
  @@index([playerId])
}

model Standing {
  id             String     @id @default(cuid())
  tournamentId   String
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId         String
  team           Team       @relation(fields: [teamId], references: [id])
  groupName      String?
  points         Int        @default(0)
  gamesPlayed    Int        @default(0)
  wins           Int        @default(0)
  draws          Int        @default(0)
  losses         Int        @default(0)
  goalsFor       Int        @default(0)
  goalsAgainst   Int        @default(0)
  goalDifference Int        @default(0)
  penaltyPoints  Int        @default(0)
  defaultWins    Int        @default(0)
  defaultLosses  Int        @default(0)

  @@unique([tournamentId, teamId])
}

model Booking {
  id            String        @id @default(cuid())
  venueId       String
  venue         Venue         @relation(fields: [venueId], references: [id])
  date          DateTime
  startTime     String
  endTime       String
  customerName  String
  customerPhone String
  customerEmail String?
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([venueId, date])
}

model Program {
  id          String             @id @default(cuid())
  name        String
  type        ProgramType
  venueId     String
  venue       Venue              @relation(fields: [venueId], references: [id])
  schedule    String
  monthlyFee  Int                @default(500)
  maxStudents Int                @default(30)
  description String?
  imageUrl    String?
  enrollments   SchoolEnrollment[]
  notifications Notification[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model SchoolEnrollment {
  id          String           @id @default(cuid())
  programId   String
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ACTIVE)
  studentName String
  studentAge  Int?
  parentName  String?
  parentPhone String?
  notes       String?
  enrolledAt  DateTime         @default(now())

  @@unique([programId, studentId])
  @@index([programId])
  @@index([studentId])
}

model CommercialSpace {
  id                   String      @id @default(cuid())
  venueId              String
  venue                Venue       @relation(fields: [venueId], references: [id])
  type                 SpaceType
  label                String?
  price                Int
  contractMonths       Int         @default(6)
  status               SpaceStatus @default(AVAILABLE)
  tenantName           String?
  tenantPhone          String?
  tenantEmail          String?
  stripeSubscriptionId String?
  stripePriceId        String?
  description          String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Payment {
  id                   String        @id @default(cuid())
  stripePaymentId      String?       @unique
  stripeSubscriptionId String?
  stripeSessionId      String?       @unique
  amount               Int
  applicationFee       Int           @default(0)
  currency             String        @default("mxn")
  status               PaymentStatus @default(PENDING)
  type                 PaymentType
  userId               String?
  user                 User?         @relation(fields: [userId], references: [id])
  venueId              String?
  venue                Venue?        @relation(fields: [venueId], references: [id])
  tournamentId         String?
  bookingId            String?
  spaceId              String?
  description          String?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId])
  @@index([venueId])
}

model Notification {
  id           String               @id @default(cuid())
  title        String
  body         String
  audience     NotificationAudience @default(ALL)
  venueId      String?
  venue        Venue?               @relation(fields: [venueId], references: [id])
  tournamentId String?
  tournament   Tournament?          @relation(fields: [tournamentId], references: [id])
  teamId       String?
  team         Team?                @relation(fields: [teamId], references: [id])
  programId    String?
  program      Program?             @relation(fields: [programId], references: [id])
  authorId     String
  author       User                 @relation(fields: [authorId], references: [id])
  reads        NotificationRead[]
  createdAt    DateTime             @default(now())

  @@index([audience])
  @@index([venueId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([programId])
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
}
